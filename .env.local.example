# Supabase — Replace with your project values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — Replace with your test keys
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Fluxitron — Custom Store Connector
FLUXITRON_API_KEY=your_generated_api_key
FLUXITRON_WEBHOOK_URL=https://api.fluxitron.com/webhooks/custom/your_store_id
FLUXITRON_WEBHOOK_API_KEY=flx_whk_your_webhook_key
